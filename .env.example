# =====================================================
# 야구 승리 예측 시스템 - 환경변수 예시
# 이 파일을 복사해서 .env 로 만들고 실제 값을 입력하세요
# cp .env.example .env
# =====================================================

# --- PostgreSQL ---
POSTGRES_DB=baseball
POSTGRES_USER=baseball
POSTGRES_PASSWORD=your_strong_password_here

# SQLAlchemy 비동기 접속 URL (Docker 내부: postgres 서비스명 사용)
DATABASE_URL=postgresql+asyncpg://baseball:your_strong_password_here@postgres:5432/baseball

# 로컬 개발용 (Docker 없이 직접 실행 시)
# DATABASE_URL=postgresql+asyncpg://baseball:your_strong_password_here@localhost:5432/baseball

# --- Redis ---
REDIS_URL=redis://redis:6379/0
# 로컬 개발용
# REDIS_URL=redis://localhost:6379/0

# --- Anthropic Claude API ---
# https://console.anthropic.com/ 에서 발급
ANTHROPIC_API_KEY=sk-ant-api03-...

# --- OpenWeatherMap API ---
# https://openweathermap.org/api/one-call-3 에서 발급 (One Call API 3.0)
OWM_API_KEY=your_owm_api_key_here

# --- 앱 설정 ---
# 리그 선택: KBO 또는 MLB
LEAGUE=MLB

# 모델 파일 저장 경로
MODEL_PATH=/app/ml_models

# 스케줄러 타임존
# KBO: Asia/Seoul
# MLB: America/New_York
SCHEDULER_TIMEZONE=America/New_York

# --- statiz.co.kr (KBO 스탯 초기 시드 — Railway Variables에도 동일하게 설정) ---
STATIZ_ID=your_statiz_email@example.com
STATIZ_PW=your_statiz_password

# 로그 레벨: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --- LLM 해설 비용 제어 ---
# 개발 중에는 false 로 설정해 API 비용 절감
LLM_EXPLANATIONS_ENABLED=true

# --- Next.js 프론트엔드 ---
# Docker 내부에서 백엔드 서비스명으로 접근
NEXT_PUBLIC_API_URL=http://backend:8000
# 로컬 개발용
# NEXT_PUBLIC_API_URL=http://localhost:8000
